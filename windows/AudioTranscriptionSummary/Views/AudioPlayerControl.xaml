<UserControl
    x:Class="AudioTranscriptionSummary.Views.AudioPlayerControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Orientation="Horizontal" Spacing="8" Padding="4">
        <Button x:Name="PlayPauseBtn" Content="&#xE768;"
                FontFamily="Segoe MDL2 Assets" Click="OnPlayPause" Width="36" Height="36" />
        <Slider x:Name="PositionSlider" Width="250" Minimum="0" Maximum="100" />
        <TextBlock x:Name="TimeText" Text="00:00 / 00:00" VerticalAlignment="Center" FontSize="12" />
    </StackPanel>
</UserControl>
