<!-- MainPage.xaml -->
<!-- 共通 UI レイアウト: 全セクション折りたたみ可能、テキストエリア自動フィット -->
<Page
    x:Class="AudioTranscriptionSummary.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AudioTranscriptionSummary.Views">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ツールバー: 録音/停止 → キャンセル → エクスポート → 設定 -->
        <CommandBar Grid.Row="0" DefaultLabelPosition="Right">
            <AppBarButton x:Name="RecordButton" Icon="Microphone" Label="録音" Click="OnRecordClick" />
            <AppBarButton x:Name="CancelButton" Icon="Cancel" Label="キャンセル" Visibility="Collapsed" Click="OnCancelClick" />
            <AppBarButton Icon="Save" Label="エクスポート" Click="OnExportClick" />
            <AppBarButton Icon="Setting" Label="設定" Click="OnSettingsClick" />
        </CommandBar>

        <!-- メインコンテンツ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="1">

                <!-- 入力（折りたたみ可能） -->
                <Expander Header="入力" IsExpanded="True">
                    <StackPanel Spacing="8" Padding="8">
                        <!-- 音源選択（画面録画を含む） -->
                        <ComboBox x:Name="AudioSourcePicker" Header="入力ソース" />
                        <!-- レベルメーター -->
                        <ProgressBar x:Name="LevelMeter" Maximum="1" />
                        <!-- 画面プレビュー（録画中のみ） -->
                        <Image x:Name="ScreenPreview" MaxHeight="100" Visibility="Collapsed" />
                    </StackPanel>
                </Expander>

                <!-- リアルタイム文字起こし（折りたたみ可能、設定連動で表示/非表示） -->
                <Expander x:Name="RealtimeSection" Header="リアルタイム文字起こし" IsExpanded="True">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <!-- 文字起こしプレビュー + コピーボタン -->
                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Padding="4">
                                <Button x:Name="RealtimeCopyBtn" Content="コピー" Click="OnCopyRealtime" />
                            </StackPanel>
                            <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                <TextBlock x:Name="RealtimeText" TextWrapping="Wrap" IsTextSelectionEnabled="True" Padding="8" />
                            </ScrollViewer>
                        </StackPanel>
                        <!-- リアルタイム翻訳 -->
                        <StackPanel Grid.Column="1">
                            <StackPanel Orientation="Horizontal" Spacing="4" Padding="4">
                                <ComboBox x:Name="RealtimeTranslateLang" />
                                <Button Content="コピー" Click="OnCopyRealtimeTranslation" />
                            </StackPanel>
                            <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                <TextBlock x:Name="RealtimeTranslationText" TextWrapping="Wrap" IsTextSelectionEnabled="True" Padding="8" />
                            </ScrollViewer>
                        </StackPanel>
                    </Grid>
                </Expander>

                <!-- 音声文字起こし（折りたたみ可能） -->
                <Expander Header="音声文字起こし" IsExpanded="True">
                    <StackPanel>
                        <!-- ファイル選択（点線枠） -->
                        <Border BorderBrush="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                BorderThickness="1" CornerRadius="4" Padding="8" Margin="8,4"
                                Background="Transparent">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE896;" />
                                <TextBlock Text="ドラッグ＆ドロップで対応ファイルをアップロード" VerticalAlignment="Center" />
                                <Button Content="ファイルを選択" Click="OnFilePickClick" />
                            </StackPanel>
                        </Border>
                        <!-- プレーヤー（常時表示） -->
                        <local:AudioPlayerControl Margin="8,2" />
                        <!-- 文字起こし結果 + 翻訳 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal" Spacing="4" Padding="4">
                                    <ComboBox x:Name="TranscriptLang" />
                                    <Button Content="文字起こし＋要約" Click="OnTranscribeClick" />
                                    <Button Content="コピー" Click="OnCopyTranscript" HorizontalAlignment="Right" />
                                </StackPanel>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <TextBlock x:Name="TranscriptText" TextWrapping="Wrap" IsTextSelectionEnabled="True" Padding="8" />
                                </ScrollViewer>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <StackPanel Orientation="Horizontal" Spacing="4" Padding="4">
                                    <ComboBox x:Name="TranscriptTranslateLang" />
                                    <Button Content="翻訳" Click="OnTranslateTranscript" />
                                    <Button Content="コピー" Click="OnCopyTranscriptTranslation" />
                                </StackPanel>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <TextBlock x:Name="TranscriptTranslationText" TextWrapping="Wrap" IsTextSelectionEnabled="True" Padding="8" />
                                </ScrollViewer>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Expander>

                <!-- 要約（折りたたみ可能） -->
                <Expander Header="要約" IsExpanded="True">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Padding="4">
                                <Button Content="コピー" Click="OnCopySummary" />
                            </StackPanel>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBlock x:Name="SummaryText" TextWrapping="Wrap" IsTextSelectionEnabled="True" Padding="8" />
                            </ScrollViewer>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <StackPanel Orientation="Horizontal" Spacing="4" Padding="4">
                                <ComboBox x:Name="SummaryTranslateLang" />
                                <Button Content="翻訳" Click="OnTranslateSummary" />
                                <Button Content="コピー" Click="OnCopySummaryTranslation" />
                            </StackPanel>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBlock x:Name="SummaryTranslationText" TextWrapping="Wrap" IsTextSelectionEnabled="True" Padding="8" />
                            </ScrollViewer>
                        </StackPanel>
                    </Grid>
                </Expander>

            </StackPanel>
        </ScrollViewer>

        <!-- ステータスバー -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Padding="8,3"
                    Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
            <TextBlock Text="CPU:" Margin="0,0,4,0" FontSize="11" />
            <TextBlock x:Name="AppCpuText" Text="アプリ 0%" Margin="0,0,8,0" FontSize="11" />
            <TextBlock Text="/" Margin="0,0,8,0" FontSize="11" />
            <TextBlock x:Name="SystemCpuText" Text="全体 0%" Margin="0,0,16,0" FontSize="11" />
            <TextBlock Text="メモリ:" Margin="0,0,4,0" FontSize="11" />
            <TextBlock x:Name="MemoryText" Text="0 MB / 0 GB (0%)" FontSize="11" />
        </StackPanel>
    </Grid>
</Page>
