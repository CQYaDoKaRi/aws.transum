<Page
    x:Class="AudioTranscriptionSummary.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    AllowDrop="True" DragOver="OnDragOver" Drop="OnDrop">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <CommandBar Grid.Row="0" DefaultLabelPosition="Right">
            <AppBarButton x:Name="RecordButton" Icon="Microphone" Label="録音" Click="OnRecordClick" />
            <AppBarButton x:Name="StopRecordButton" Icon="Stop" Label="停止" Visibility="Collapsed" Click="OnStopRecordClick" />
            <AppBarButton x:Name="CancelButton" Icon="Cancel" Label="キャンセル" Visibility="Collapsed" Click="OnCancelClick" />
            <AppBarButton Icon="Setting" Label="設定" Click="OnSettingsClick" />
        </CommandBar>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="4" Padding="8">

                <!-- ===== 入力 ===== -->
                <Expander x:Name="InputSection" IsExpanded="True" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                    <Expander.Header>
                        <Border Background="#200078D4" CornerRadius="4" Padding="10,6" Margin="-12,-6,-12,-6">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE720;" Foreground="#0078D4" FontSize="16" />
                                <TextBlock Text="入力" FontWeight="SemiBold" FontSize="14" />
                            </StackPanel>
                        </Border>
                    </Expander.Header>
                    <StackPanel Spacing="8" Padding="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ComboBox x:Name="AudioSourcePicker" Header="入力ソース" DisplayMemberPath="Name" />
                            <ToggleSwitch x:Name="RealtimeToggle" Header="リアルタイム文字起こし" IsOn="True" Toggled="OnRealtimeToggled" VerticalAlignment="Bottom" />
                        </StackPanel>
                        <TextBlock Text="音声レベル" FontSize="12" />
                        <ProgressBar x:Name="LevelMeter" Maximum="1" Value="0" Height="8" />
                    </StackPanel>
                </Expander>

                <!-- ===== リアルタイム文字起こし ===== -->
                <Expander x:Name="RealtimeSection" IsExpanded="True" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                    <Expander.Header>
                        <Border Background="#20E74856" CornerRadius="4" Padding="10,6" Margin="-12,-6,-12,-6">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8D6;" Foreground="#E74856" FontSize="16" />
                                <TextBlock Text="リアルタイム文字起こし" FontWeight="SemiBold" FontSize="14" />
                            </StackPanel>
                        </Border>
                    </Expander.Header>
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,4,0">
                            <StackPanel Orientation="Horizontal" Spacing="8" Padding="4">
                                <ComboBox x:Name="RealtimeLangCombo" Width="160" />
                                <!-- 検出言語ラベル（自動検出時） -->
                                <Border x:Name="LanguageBadge" Background="{ThemeResource SystemAccentColor}" CornerRadius="4" Padding="6,2" Visibility="Collapsed">
                                    <TextBlock x:Name="LanguageBadgeText" FontSize="11" Foreground="White" />
                                </Border>
                                <!-- 再判別ボタン（自動検出時、緑アイコン） -->
                                <Button x:Name="RedetectLangBtn" Visibility="Collapsed" Click="OnRedetectLanguageClick" ToolTipService.ToolTip="言語を再判別" Padding="4">
                                    <FontIcon Glyph="&#xE72C;" FontSize="14" Foreground="Green" />
                                </Button>
                                <TextBlock x:Name="RealtimeErrorText" FontSize="11" Foreground="Red" VerticalAlignment="Center" />
                                <Button x:Name="CopyRealtimeBtn" IsEnabled="False" Click="OnCopyRealtime"><StackPanel Orientation="Horizontal" Spacing="4"><FontIcon Glyph="&#xE8C8;" FontSize="12" /><TextBlock Text="コピー" /></StackPanel></Button>
                            </StackPanel>
                            <Border BorderBrush="{ThemeResource SystemControlForegroundBaseMediumBrush}" BorderThickness="1" CornerRadius="4" Margin="4" Height="150">
                                <ScrollViewer x:Name="RealtimeScrollViewer" VerticalScrollBarVisibility="Auto">
                                    <RichTextBlock x:Name="RealtimeRichText" TextWrapping="Wrap" IsTextSelectionEnabled="True" Padding="8">
                                        <Paragraph><Run x:Name="RealtimeFinalRun" /><Run x:Name="RealtimePartialRun" Foreground="Gray" /></Paragraph>
                                    </RichTextBlock>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="4,0,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="4" Padding="4">
                                <ComboBox x:Name="RealtimeTranslateLang" Width="120" />
                                <ProgressRing x:Name="RealtimeTranslateProgress" IsActive="False" Width="16" Height="16" />
                                <Button x:Name="CopyRealtimeTransBtn" IsEnabled="False" Click="OnCopyRealtimeTranslation"><StackPanel Orientation="Horizontal" Spacing="4"><FontIcon Glyph="&#xE8C8;" FontSize="12" /><TextBlock Text="コピー" /></StackPanel></Button>
                            </StackPanel>
                            <TextBox x:Name="RealtimeTranslationText" TextWrapping="Wrap" IsReadOnly="True"
                                     AcceptsReturn="True" Height="150"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     BorderBrush="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                     BorderThickness="1" CornerRadius="4" Margin="4" Padding="8" />
                        </StackPanel>
                    </Grid>
                </Expander>

                <!-- ===== 音声文字起こし ===== -->
                <Expander x:Name="TranscriptSection" IsExpanded="True" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                    <Expander.Header>
                        <Border Background="#2016C60C" CornerRadius="4" Padding="10,6" Margin="-12,-6,-12,-6">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8C1;" Foreground="#16C60C" FontSize="16" />
                                <TextBlock Text="音声文字起こし" FontWeight="SemiBold" FontSize="14" />
                            </StackPanel>
                        </Border>
                    </Expander.Header>
                    <StackPanel Margin="0,4">
                        <Border x:Name="DropZone" BorderBrush="{ThemeResource SystemControlForegroundBaseMediumBrush}" BorderThickness="1" CornerRadius="4" Padding="8" Margin="8,4" Background="Transparent" AllowDrop="True" DragOver="OnDragOver" Drop="OnDrop">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE898;" FontSize="20" />
                                <TextBlock Text="ドラッグ＆ドロップで対応ファイルをアップロード" VerticalAlignment="Center" />
                                <Button Click="OnFilePickClick"><StackPanel Orientation="Horizontal" Spacing="4"><FontIcon Glyph="&#xE8E5;" FontSize="14" /><TextBlock Text="ファイルを選択" /></StackPanel></Button>
                            </StackPanel>
                        </Border>
                        <Grid x:Name="PlayerPanel" Padding="8,4" Visibility="Collapsed">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <Button x:Name="PlayPauseButton" Content="&#xE768;" FontFamily="Segoe MDL2 Assets" Click="OnPlayPause" Width="36" Height="36" Grid.Column="0" />
                            <Slider x:Name="PositionSlider" Minimum="0" Margin="8,0" ValueChanged="OnPositionSliderChanged" Grid.Column="1" />
                            <TextBlock x:Name="TimeText" Text="00:00 / 00:00" VerticalAlignment="Center" FontSize="12" Grid.Column="2" />
                        </Grid>
                        <TextBlock x:Name="FileInfoText" Padding="8,2" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                <StackPanel Orientation="Horizontal" Spacing="4" Padding="4">
                                    <ComboBox x:Name="TranscriptionLangCombo" Width="160" />
                                    <Button x:Name="TranscribeButton" Click="OnTranscribeClick"><StackPanel Orientation="Horizontal" Spacing="4"><FontIcon Glyph="&#xE8C1;" FontSize="14" /><TextBlock Text="文字起こし＋要約" /></StackPanel></Button>
                                    <Button x:Name="CopyTranscriptBtn" IsEnabled="False" Click="OnCopyTranscript"><StackPanel Orientation="Horizontal" Spacing="4"><FontIcon Glyph="&#xE8C8;" FontSize="12" /><TextBlock Text="コピー" /></StackPanel></Button>
                                </StackPanel>
                                <TextBox x:Name="TranscriptText" TextWrapping="Wrap" IsReadOnly="True"
                                         AcceptsReturn="True" Height="150"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         BorderBrush="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                         BorderThickness="1" CornerRadius="4" Margin="4" Padding="8" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                <StackPanel Orientation="Horizontal" Spacing="4" Padding="4">
                                    <ComboBox x:Name="TranscriptTranslateLang" Width="120" />
                                    <Button x:Name="TranslateTranscriptBtn" IsEnabled="False" Click="OnTranslateTranscript"><StackPanel Orientation="Horizontal" Spacing="4"><FontIcon Glyph="&#xE8C3;" FontSize="12" /><TextBlock Text="翻訳" /></StackPanel></Button>
                                    <ProgressRing x:Name="TranscriptTranslateProgress" IsActive="False" Width="16" Height="16" />
                                    <Button x:Name="CopyTranscriptTransBtn" IsEnabled="False" Click="OnCopyTranscriptTranslation"><StackPanel Orientation="Horizontal" Spacing="4"><FontIcon Glyph="&#xE8C8;" FontSize="12" /><TextBlock Text="コピー" /></StackPanel></Button>
                                </StackPanel>
                                <TextBox x:Name="TranscriptTranslationText" TextWrapping="Wrap" IsReadOnly="True"
                                         AcceptsReturn="True" Height="150"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         BorderBrush="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                         BorderThickness="1" CornerRadius="4" Margin="4" Padding="8" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Expander>

                <!-- ===== 要約 ===== -->
                <Expander x:Name="SummarySection" IsExpanded="True" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                    <Expander.Header>
                        <Border Background="#20F7630C" CornerRadius="4" Padding="10,6" Margin="-12,-6,-12,-6">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8A5;" Foreground="#F7630C" FontSize="16" />
                                <TextBlock Text="要約" FontWeight="SemiBold" FontSize="14" />
                            </StackPanel>
                        </Border>
                    </Expander.Header>
                    <StackPanel Margin="0,4">
                        <!-- 基盤モデル選択 + プロンプト + ボタン -->
                        <StackPanel Orientation="Horizontal" Spacing="4" Margin="4,0,4,4">
                            <ComboBox x:Name="BedrockModelCombo" Width="200" />
                        </StackPanel>
                        <Grid Margin="4,0,4,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="140" /></Grid.ColumnDefinitions>
                            <TextBox x:Name="SummaryPromptBox" Grid.Column="0" PlaceholderText="追加プロンプト（例: 箇条書きで要約して）"
                                     AcceptsReturn="True" TextWrapping="Wrap" MinHeight="40" MaxHeight="80" />
                            <StackPanel Grid.Column="1" Spacing="4" Margin="4,0,0,0">
                                <Button x:Name="SummaryFileBtn" Click="OnSummaryFileClick" HorizontalAlignment="Stretch">
                                    <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                        <FontIcon Glyph="&#xE8E5;" FontSize="12" />
                                        <TextBlock Text="ファイルから要約" />
                                    </StackPanel>
                                </Button>
                                <Button x:Name="ResummarizeBtn" Click="OnResummarizeClick" HorizontalAlignment="Stretch">
                                    <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                        <FontIcon Glyph="&#xE8A5;" FontSize="12" />
                                        <TextBlock Text="要約" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Padding="4">
                                    <Button x:Name="CopySummaryBtn" IsEnabled="False" Click="OnCopySummary"><StackPanel Orientation="Horizontal" Spacing="4"><FontIcon Glyph="&#xE8C8;" FontSize="12" /><TextBlock Text="コピー" /></StackPanel></Button>
                                </StackPanel>
                                <TextBox x:Name="SummaryText" TextWrapping="Wrap" IsReadOnly="True"
                                         AcceptsReturn="True" Height="150"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         BorderBrush="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                         BorderThickness="1" CornerRadius="4" Margin="4" Padding="8" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                <StackPanel Orientation="Horizontal" Spacing="4" Padding="4">
                                    <ComboBox x:Name="SummaryTranslateLang" Width="120" />
                                    <Button x:Name="TranslateSummaryBtn" IsEnabled="False" Click="OnTranslateSummary"><StackPanel Orientation="Horizontal" Spacing="4"><FontIcon Glyph="&#xE8C3;" FontSize="12" /><TextBlock Text="翻訳" /></StackPanel></Button>
                                    <ProgressRing x:Name="SummaryTranslateProgress" IsActive="False" Width="16" Height="16" />
                                    <Button x:Name="CopySummaryTransBtn" IsEnabled="False" Click="OnCopySummaryTranslation"><StackPanel Orientation="Horizontal" Spacing="4"><FontIcon Glyph="&#xE8C8;" FontSize="12" /><TextBlock Text="コピー" /></StackPanel></Button>
                                </StackPanel>
                                <TextBox x:Name="SummaryTranslationText" TextWrapping="Wrap" IsReadOnly="True"
                                         AcceptsReturn="True" Height="150"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         BorderBrush="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                         BorderThickness="1" CornerRadius="4" Margin="4" Padding="8" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Expander>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" Background="#E0E0E0" Padding="8,3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel x:Name="StatusProgressPanel" Orientation="Horizontal" Spacing="8" Grid.Column="0" Visibility="Collapsed" VerticalAlignment="Center">
                <ProgressBar x:Name="StatusProgressBar" Width="120" Maximum="100" Value="0" VerticalAlignment="Center" />
                <ProgressRing x:Name="StatusProgressRing" IsActive="False" Width="14" Height="14" Visibility="Collapsed" />
                <TextBlock x:Name="StatusProgressText" FontSize="11" Foreground="#808080" VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock Grid.Column="1" HorizontalAlignment="Right" FontSize="11" Foreground="#808080">
                <Run Text="CPU: " /><Run x:Name="AppCpuText" Text="アプリ 0%" /><Run Text=" / " /><Run x:Name="SystemCpuText" Text="全体 0%" /><Run Text="    メモリ: " /><Run x:Name="MemoryText" Text="0 MB / 0 GB (0%)" />
            </TextBlock>
        </Grid>
    </Grid>
</Page>
